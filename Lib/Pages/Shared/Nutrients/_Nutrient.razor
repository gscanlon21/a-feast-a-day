@page "/nutrients/dietaryintakes"
@inject DisplayHelper DH
@inject IOptions<SiteSettings> SiteSettings
@using Core.Consts;
@using Core.Dtos.Nutrients
@using Core.Models.Options
@using Microsoft.Extensions.Options
@using Core.Models.Recipe
@using Core.Models.User
@using Core.Models.Newsletter
@using Core.Dtos.Ingredient

@* Use `em` for spacing and font sizes--it's more consistent across fonts/mediums. *@
<div style="flex:1 0 min(calc(100% - 20px), 300px);padding:10px;position:relative;display:flex;flex-direction:column;
            border-bottom:4px solid currentColor;border-image-slice:1;outline:1px solid currentColor;background-color:transparent;">

    <div> @* For margin collapse. *@
        <h3 style="margin-block-start:0;margin-block-end:.4em;font-size:1.2em;line-height:1.2;display:flex;gap:.8ch;">
            <span style="flex:1 1 auto;">
                <span style="text-decoration:underline;">@Model.Key</span>
            </span>

            @if (User != null)
            {
                <a class="allow-demo" style="text-decoration:none;margin:-10px -10px 0 0;padding:10px 8px 0 0;" target="_blank" href="@DH.NutrientLink(User, Model.Id)">&#127760;</a>
            }
        </h3>

        <div style="margin-block:.5em;font-size:x-small;word-break:break-word;"><b>Key</b>: @Model.Key</div>
        <div style="margin-block:.5em;font-size:x-small;word-break:break-word;"><b>Name</b>: @Model.Name</div>
        <div style="margin-block:.5em;font-size:x-small;word-break:break-word;"><b>Order</b>: @Model.Order</div>
        <div style="margin-block:.5em;font-size:x-small;word-break:break-word;"><b>Notes</b>: @Model.Notes</div>
    </div>
</div>

@code {
    [CascadingParameter]
    public Core.Dtos.User.UserNewsletterDto? User { get; set; }

    [Parameter, EditorRequired]
    public NutrientDto Model { get; set; } = null!;
}